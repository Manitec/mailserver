# Copy this file to .env and fill in your Zoho Mail360 API credentials
# Get these from your Zoho Developer Console: https://api-console.zoho.com/

CLIENT_ID=your_zoho_client_id_here
CLIENT_SECRET=your_zoho_client_secret_here
REFRESH_TOKEN=your_zoho_refresh_token_here

# Optional: Set this if using Render Disk for persistent storage
# DB_PATH=/opt/render/project/src/data/users.db
