# Copy this file to .env and fill in your values.
# Get Zoho credentials from: https://api-console.zoho.com/

CLIENT_ID=your_zoho_client_id_here
CLIENT_SECRET=your_zoho_client_secret_here
REFRESH_TOKEN=your_zoho_refresh_token_here

# ---------------------------------------------------------------------------
# User seeding — add one MAIL_USER_N per user (N = 1, 2, 3 ...)
# Format: username:plaintext_password:mail360_account_key:email@domain
# These are loaded on every startup via seed_users_from_env() in main.py.
# Users are inserted with INSERT OR IGNORE so existing rows are never clobbered.
# ---------------------------------------------------------------------------
MAIL_USER_1=joe:supersecretpassword:YourMail360AccountKey:joe@manitec.pw
# MAIL_USER_2=jane:anotherpassword:JaneAccountKey:jane@manitec.pw

# Optional: override the SQLite db path (local dev only — Render uses ephemeral fs)
# DB_PATH=/tmp/users.db
